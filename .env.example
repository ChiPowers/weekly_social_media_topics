# .env.example — copy to .env and fill in real values
# Never commit .env to git

ANTHROPIC_API_KEY=your-anthropic-api-key-here
EMAIL_RECIPIENT=you@example.com

# Optional: maximum API calls per run (default: 50)
API_CALL_BUDGET=50
TAVILY_API_KEY=tvly-YOUR_API_KEY_HERE
RESEND_API_KEY=re_YOUR_API_KEY_HERE
# EMAIL_FROM must use a domain you have verified in your Resend dashboard.
# For testing only, Resend allows: onboarding@resend.dev (sends only to your own account email)
EMAIL_FROM=Content Agent <agent@yourdomain.com>
